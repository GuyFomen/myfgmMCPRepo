# -------------------------------------------------------
# SQL Server connection settings
# -------------------------------------------------------

# SQL Server localhost 
MSSQL_DRIVER=ODBC Driver 17 for SQL Server


# Server hostname or IP 
MSSQL_SERVER=localhost

# MSSQL_PORT=1433 not need
MSSQL_DATABASE=WoundCareDB

# Leave BOTH blank → triggers Trusted_Connection=yes (Windows Auth)
MSSQL_USERNAME=
MSSQL_PASSWORD=

# connection string shows Encrypt=False and TrustServerCertificate=False
# so we keep this 'no' — no self-signed cert issue on localhost
MSSQL_TRUST_SERVER_CERT=no
